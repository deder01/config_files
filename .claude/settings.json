{
  "model": "opus",
  "effortLevel": "high",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git ls-files*)",
      "Bash(git ls-tree*)",
      "Bash(git remote*)",
      "Bash(git rev-parse*)",
      "Bash(git blame*)",
      "Bash(git config --get*)",
      "Bash(git config --list*)",
      "Bash(git add*)",
      "Bash(/usr/bin/git --git-dir=$HOME/.cfg/ --work-tree=$HOME add*)",
      "Bash(/usr/bin/git --git-dir=$HOME/.cfg/ --work-tree=$HOME status*)",
      "Bash(/usr/bin/git --git-dir=$HOME/.cfg/ --work-tree=$HOME log*)",
      "Bash(/usr/bin/git --git-dir=$HOME/.cfg/ --work-tree=$HOME diff*)",
      "Bash(/usr/bin/git --git-dir=$HOME/.cfg/ --work-tree=$HOME branch*)",
      "Bash(/usr/bin/git --git-dir=$HOME/.cfg/ --work-tree=$HOME show*)",
      "Bash(/usr/bin/git --git-dir=$HOME/.cfg/ --work-tree=$HOME ls-files*)",
      "Bash(/usr/bin/git --git-dir=$HOME/.cfg/ --work-tree=$HOME ls-tree*)",
      "Bash(ssh -T git@github.com*)",
      "Bash(ls*)",
      "Bash(which*)",
      "Bash(node*)",
      "Bash(npm list*)",
      "Bash(npm --version*)",
      "Bash(npx --version*)",
      "Bash(tsc --version*)",
      "Bash(pwd*)",
      "Bash(echo*)",
      "Bash(env*)",
      "Bash(printenv*)",
      "Bash(uname*)",
      "Bash(whoami*)",
      "Bash(hostname*)",
      "Bash(date*)",
      "Bash(wc*)"
    ]
  }
}
